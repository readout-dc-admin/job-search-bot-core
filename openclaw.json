{
  "agents": {
    "defaults": {
      "models": {
        "openai/gpt-5.5": {
          "alias": "GPT"
        }
      },
      "model": {
        "primary": "openai/gpt-5.5"
      }
    }
  },
  "gateway": {
    "mode": "remote",
    "bind": "lan",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "brave",
        "enabled": true
      }
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "brave": {
        "enabled": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "commands": {
    "ownerAllowFrom": [
      "telegram:7975055818"
    ]
  }
}
